---
import Shell from "../layouts/Shell.astro";
---

<Shell title="axiom-web-lite">
  <h2 style="margin-bottom:1rem;font-size:1.1rem;">Streaming shell experiment</h2>
  <p style="color:var(--muted);margin-bottom:1.5rem;line-height:1.6;">
    This is a minimal prototype that demonstrates perceived-performance streaming
    against the local Axiom API. It is intentionally plain — not a design showcase.
  </p>
  <a
    href="/chat"
    style="background:var(--accent);color:#fff;padding:0.6rem 1.4rem;border-radius:6px;text-decoration:none;font-size:0.9rem;"
  >
    Open chat →
  </a>
</Shell>
